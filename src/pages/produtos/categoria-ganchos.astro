---
import LayoutBase from '../../layouts/LayoutBase.astro';
---

<LayoutBase title="Ganchos - MM Montagens">
    <section class="relative w-full h-[200px] flex items-center justify-center overflow-hidden border-t border-mm-blue/20">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&q=80');"></div>
        <div class="absolute inset-0 bg-mm-darkblue/90 mix-blend-multiply"></div>
        <div class="relative z-10 text-center text-white flex flex-col mt-4">
            <h1 class="text-[60px] font-condensed font-bold leading-none tracking-tight drop-shadow-md uppercase">GANCHOS</h1>
        </div>
    </section>

    <section class="w-full py-12 bg-gray-50 min-h-[500px]">
        <div class="container mx-auto px-8 lg:px-24">
            
            <div class="flex justify-between items-center mb-10 border-b border-gray-200 pb-4">
                <a href="/produtos" class="text-gray-500 hover:text-mm-blue font-semibold flex items-center gap-2 transition">
                    <i class="fas fa-arrow-left"></i> Voltar para Categorias
                </a>
                
                <a href="/carrinho" class="bg-mm-blue text-white px-5 py-2 rounded shadow flex items-center gap-2 hover:bg-mm-darkblue transition">
                    <i class="fas fa-shopping-cart"></i> 
                    <span class="font-bold">Ir para Carrinho</span>
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                
                <div class="bg-white rounded-lg shadow border border-gray-100 overflow-hidden flex flex-col">
                    <div class="h-[220px] bg-gray-100 flex items-center justify-center p-4">
                        <img id="img-prod-1" src="/midia/gancho para painel canaletado branco fundo branco.png" alt="Gancho Branco" class="max-h-full object-contain mix-blend-multiply">
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="font-bold text-gray-800 text-[15px] leading-tight mb-1">Gancho para Painel Canaletado (Branco)</h3>
                        <p class="text-gray-400 text-xs mb-4">Código: GPC-001</p>
                        
                        <div class="mt-auto pt-4 border-t border-gray-100 flex gap-2">
                            <input id="qty-prod-1" type="number" min="1" placeholder="Qtd" class="w-20 border border-gray-300 rounded px-2 py-2 text-gray-700 font-bold focus:outline-none focus:border-mm-blue text-center">
                            
                            <button onclick="adicionarAoCarrinho('prod-1', 'Gancho Painel Branco', 'GPC-001', 'img-prod-1', 'qty-prod-1')" class="flex-1 bg-[#25D366] hover:bg-[#20ba5a] text-white font-bold rounded py-2 transition shadow flex justify-center items-center gap-2 text-sm">
                                <i class="fas fa-cart-plus"></i> Adicionar
                            </button>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow border border-gray-100 overflow-hidden flex flex-col">
                    <div class="h-[220px] bg-gray-100 flex items-center justify-center p-4">
                        <img id="img-prod-2" src="/midia/gancho para painel canaletado preto fundo branco.png" alt="Gancho Preto" class="max-h-full object-contain mix-blend-multiply">
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="font-bold text-gray-800 text-[15px] leading-tight mb-1">Gancho para Painel Canaletado (Preto)</h3>
                        <p class="text-gray-400 text-xs mb-4">Código: GPC-002</p>
                        
                        <div class="mt-auto pt-4 border-t border-gray-100 flex gap-2">
                            <input id="qty-prod-2" type="number" min="1" placeholder="Qtd" class="w-20 border border-gray-300 rounded px-2 py-2 text-gray-700 font-bold focus:outline-none focus:border-mm-blue text-center">
                            
                            <button onclick="adicionarAoCarrinho('prod-2', 'Gancho Painel Preto', 'GPC-002', 'img-prod-2', 'qty-prod-2')" class="flex-1 bg-[#25D366] hover:bg-[#20ba5a] text-white font-bold rounded py-2 transition shadow flex justify-center items-center gap-2 text-sm">
                                <i class="fas fa-cart-plus"></i> Adicionar
                            </button>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow border border-gray-100 overflow-hidden flex flex-col">
                    <div class="h-[220px] bg-gray-100 flex items-center justify-center p-4">
                        <img id="img-prod-3" src="/midia/gancho para painel canaletado Zincado fundo branco.png" alt="Gancho Zincado" class="max-h-full object-contain mix-blend-multiply">
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <h3 class="font-bold text-gray-800 text-[15px] leading-tight mb-1">Gancho para Painel Canaletado (Zincado)</h3>
                        <p class="text-gray-400 text-xs mb-4">Código: GPC-003</p>
                        
                        <div class="mt-auto pt-4 border-t border-gray-100 flex gap-2">
                            <input id="qty-prod-3" type="number" min="1" placeholder="Qtd" class="w-20 border border-gray-300 rounded px-2 py-2 text-gray-700 font-bold focus:outline-none focus:border-mm-blue text-center">
                            
                            <button onclick="adicionarAoCarrinho('prod-3', 'Gancho Painel Zincado', 'GPC-003', 'img-prod-3', 'qty-prod-3')" class="flex-1 bg-[#25D366] hover:bg-[#20ba5a] text-white font-bold rounded py-2 transition shadow flex justify-center items-center gap-2 text-sm">
                                <i class="fas fa-cart-plus"></i> Adicionar
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</LayoutBase>