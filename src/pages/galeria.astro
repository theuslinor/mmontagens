---
import LayoutBase from '../layouts/LayoutBase.astro';
---

<LayoutBase title="MM Montagens - Galeria">
    <section class="relative w-full h-[280px] flex items-center justify-center overflow-hidden border-t border-mm-blue/20">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&q=80');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1489c8]/95 via-[#1489c8]/85 to-[#0e6ba0]/95 mix-blend-multiply"></div>
        
        <div class="relative z-10 text-center text-white flex flex-col mt-4">
            <h1 class="text-[75px] md:text-[90px] font-condensed font-bold leading-none tracking-tight drop-shadow-md">GALERIA</h1>
        </div>
    </section>

    <section class="w-full py-20 bg-white min-h-[500px]">
        <div class="container mx-auto px-8 lg:px-24">
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                
                <a href="#" class="relative w-full h-[260px] bg-gray-100 overflow-hidden group cursor-pointer shadow-sm hover:shadow-xl transition-shadow duration-300">
                    <img src="/midia/gancho branco para barra de gôndola fundo branco.png" alt="Ganchos" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    <h3 class="absolute bottom-5 left-5 text-white font-bold text-[20px] leading-tight pr-4 drop-shadow-md">Ganchos</h3>
                </a>

                <a href="#" class="relative w-full h-[260px] bg-gray-100 overflow-hidden group cursor-pointer shadow-sm hover:shadow-xl transition-shadow duration-300">
                    <img src="/midia/gancho para painel canaletado Zincado fundo branco.png" alt="Balcões modulados" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    <h3 class="absolute bottom-5 left-5 text-white font-bold text-[20px] leading-tight pr-4 drop-shadow-md">Balcões modulados</h3>
                </a>

                <a href="#" class="relative w-full h-[260px] bg-gray-100 overflow-hidden group cursor-pointer shadow-sm hover:shadow-xl transition-shadow duration-300">
                    <img src="/midia/gancho para painel canaletado Zincado fundo branco.png" alt="Suporte" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    <h3 class="absolute bottom-5 left-5 text-white font-bold text-[20px] leading-tight pr-4 drop-shadow-md">Suporte</h3>
                </a>

                <a href="#" class="relative w-full h-[260px] bg-gray-100 overflow-hidden group cursor-pointer shadow-sm hover:shadow-xl transition-shadow duration-300">
                    <img src="/midia/barra para gôndola fundo branco.png" alt="Outros produtos" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90 group-hover:opacity-100 transition duration-300"></div>
                    <h3 class="absolute bottom-5 left-5 text-white font-bold text-[20px] leading-tight pr-4 drop-shadow-md">Outros produtos</h3>
                </a>

            </div>
        </div>
    </section>
</LayoutBase>