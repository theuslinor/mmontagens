---
// src/pages/carrinho.astro
// Esta página não usa o LayoutBase pois tem um header simplificado focado em conversão.
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Orçamento - MM Montagens</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Montserrat', 'sans-serif'] },
                    colors: { mm: { blue: '#1489c8', darkblue: '#0d5d9c', yellow: '#fbc02d' } }
                }
            }
        }
    </script>
</head>
<body class="font-sans antialiased text-gray-800 bg-[#f4f7f6]">

    <header class="w-full bg-white h-[90px] flex items-center justify-between px-8 lg:px-24 shadow-sm relative z-50 border-b border-gray-100">
        <a href="/" class="flex items-center justify-center transition hover:scale-105">
            <img src="/midia/logo4.png" alt="MM Montagens" class="w-[140px] h-auto object-contain">    
        </a>
        <a href="/produtos" class="text-mm-blue hover:text-mm-darkblue font-bold flex items-center gap-2 transition bg-blue-50 px-4 py-2 rounded-full text-sm shadow-sm hover:shadow">
            <i class="fas fa-arrow-left"></i> Continuar Comprando
        </a>
    </header>

    <section class="container mx-auto px-4 lg:px-24 py-12 min-h-[600px]">
        
        <div class="flex items-center gap-3 mb-8 border-b border-gray-200 pb-4">
            <i class="fas fa-shopping-cart text-3xl text-mm-blue"></i>
            <h1 class="text-3xl font-black text-gray-800 tracking-tight">Meu Orçamento</h1>
        </div>

        <div class="flex flex-col lg:flex-row gap-8 items-start hidden" id="carrinho-conteudo">
            
            <div class="w-full lg:w-2/3 bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
                
                <div class="hidden md:grid grid-cols-[1fr_150px_80px] gap-4 p-4 bg-gray-50 border-b border-gray-200 text-xs font-bold text-gray-500 uppercase tracking-wider">
                    <div>Produto</div>
                    <div class="text-center">Quantidade</div>
                    <div class="text-center">Ação</div>
                </div>

                <div id="lista-carrinho" class="flex flex-col"></div>
                
                <div class="p-4 bg-gray-50 border-t border-gray-200 flex justify-between items-center">
                    <button onclick="limparCarrinho()" class="text-red-500 hover:text-red-700 text-sm font-bold flex items-center gap-2 transition">
                        <i class="fas fa-trash"></i> Esvaziar Orçamento
                    </button>
                </div>
            </div>

            <div class="w-full lg:w-1/3 bg-white rounded-xl shadow-sm border border-gray-200 p-6 sticky top-8">
                <h2 class="text-xl font-bold text-gray-800 mb-6 pb-4 border-b border-gray-100">Resumo do Pedido</h2>
                
                <div class="flex justify-between items-center mb-4 text-gray-600">
                    <span>Total de Produtos:</span>
                    <span id="resumo-total-produtos" class="font-bold text-lg">0</span>
                </div>
                
                <div class="flex justify-between items-center mb-8 text-gray-600">
                    <span>Total de Peças:</span>
                    <span id="resumo-total-pecas" class="font-black text-2xl text-mm-blue">0</span>
                </div>

                <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 mb-8">
                    <p class="text-xs text-mm-darkblue leading-relaxed text-center">
                        <i class="fas fa-info-circle mb-1 text-lg"></i><br>
                        Nossos consultores analisarão seu pedido e enviarão uma proposta comercial.
                    </p>
                </div>

                <button onclick="enviarParaWhatsApp()" class="w-full bg-[#25D366] hover:bg-[#20ba5a] text-white font-black text-lg py-4 rounded-lg shadow-lg hover:shadow-xl transition-all hover:-translate-y-1 flex justify-center items-center gap-3">
                    <i class="fab fa-whatsapp text-2xl"></i> Enviar Orçamento
                </button>
            </div>

        </div>

        <div id="carrinho-vazio" class="bg-white rounded-xl shadow-sm border border-gray-200 p-16 text-center hidden">
            <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-300">
                <i class="fas fa-shopping-basket text-4xl"></i>
            </div>
            <h2 class="text-2xl font-black text-gray-800 mb-2">Seu orçamento está vazio!</h2>
            <p class="text-gray-500 mb-8">Navegue pelas nossas categorias e adicione produtos.</p>
            <a href="/produtos" class="inline-block bg-mm-blue hover:bg-mm-darkblue text-white font-bold px-8 py-3 rounded-full transition shadow-md">
                Ver Produtos
            </a>
        </div>

    </section>

    <script src="/carrinho.js" is:inline></script>

    <script is:inline>
        function renderizarPaginaCarrinho() {
            // getCarrinho() vem do carrinho.js
            const itens = typeof getCarrinho === 'function' ? getCarrinho() : JSON.parse(localStorage.getItem("mm_montagens_carrinho")) || [];
            
            const container = document.getElementById('lista-carrinho');
            const areaConteudo = document.getElementById('carrinho-conteudo');
            const areaVazia = document.getElementById('carrinho-vazio');
            
            const resumoProdutos = document.getElementById('resumo-total-produtos');
            const resumoPecas = document.getElementById('resumo-total-pecas');

            if (itens.length === 0) {
                areaConteudo.classList.add('hidden');
                areaVazia.classList.remove('hidden');
                return;
            }

            areaConteudo.classList.remove('hidden');
            areaVazia.classList.add('hidden');
            container.innerHTML = ''; 

            let totalPecas = 0;

            itens.forEach((item, index) => {
                // Sincronizado para usar .qty
                const quantidade = parseInt(item.qty) || 0;
                totalPecas += quantidade;
                
                let imagemCorrigida = item.img;
                if(imagemCorrigida && imagemCorrigida.includes("midia/")) {
                    imagemCorrigida = "/midia/" + imagemCorrigida.split("midia/")[1];
                }
                
                container.innerHTML += `
                    <div class="grid grid-cols-1 md:grid-cols-[1fr_150px_80px] gap-4 p-4 md:p-6 border-b border-gray-100 items-center hover:bg-gray-50 transition">
                        <div class="flex items-center gap-4">
                            <div class="w-20 h-20 bg-white border border-gray-200 rounded p-1 flex-shrink-0 flex items-center justify-center">
                                <img src="${imagemCorrigida}" onerror="this.src='/midia/logo4.png'" alt="${item.nome}" class="max-h-full object-contain mix-blend-multiply">
                            </div>
                            <div class="flex flex-col">
                                <h3 class="font-bold text-gray-800 text-[15px] leading-tight md:text-base">${item.nome}</h3>
                                <span class="text-xs text-gray-400 mt-1">Cód: ${item.codigo}</span>
                            </div>
                        </div>

                        <div class="flex items-center justify-center mt-4 md:mt-0">
                            <div class="flex border border-gray-300 rounded-md overflow-hidden bg-white shadow-sm">
                                <button onclick="alterarQtd(${index}, -1)" class="w-10 h-10 text-gray-500 hover:bg-gray-100 hover:text-mm-blue transition focus:outline-none flex items-center justify-center border-r border-gray-300">
                                    <i class="fas fa-minus text-xs"></i>
                                </button>
                                <input type="number" min="1" value="${quantidade}" onchange="atualizarInputManual(${index}, this.value)" class="w-16 h-10 text-center font-bold text-gray-700 outline-none focus:ring-2 focus:ring-mm-blue appearance-none m-0 p-0">
                                <button onclick="alterarQtd(${index}, 1)" class="w-10 h-10 text-gray-500 hover:bg-gray-100 hover:text-mm-blue transition focus:outline-none flex items-center justify-center border-l border-gray-300">
                                    <i class="fas fa-plus text-xs"></i>
                                </button>
                            </div>
                        </div>

                        <div class="flex justify-center mt-2 md:mt-0">
                            <button onclick="removerItem(${index})" class="text-gray-400 hover:text-red-500 w-10 h-10 rounded-full hover:bg-red-50 transition focus:outline-none" title="Remover Produto">
                                <i class="fas fa-trash-alt text-lg"></i>
                            </button>
                        </div>
                    </div>
                `;
            });

            resumoProdutos.innerText = itens.length;
            resumoPecas.innerText = totalPecas;
        }

        function alterarQtd(index, valor) {
            let itens = getCarrinho();
            let novaQtd = (parseInt(itens[index].qty) || 1) + valor;
            
            if (novaQtd >= 1) {
                itens[index].qty = novaQtd;
                salvarCarrinho(itens); // salvarCarrinho() vem do carrinho.js
                renderizarPaginaCarrinho();
            }
        }

        function atualizarInputManual(index, valor) {
            let itens = getCarrinho();
            let novaQtd = parseInt(valor);
            
            if (novaQtd >= 1) {
                itens[index].qty = novaQtd;
            } else {
                itens[index].qty = 1;
            }
            salvarCarrinho(itens);
            renderizarPaginaCarrinho();
        }

        function removerItem(index) {
            let itens = getCarrinho();
            itens.splice(index, 1);
            salvarCarrinho(itens);
            renderizarPaginaCarrinho();
        }

        function limparCarrinho() {
            if(confirm("Tem certeza que deseja esvaziar seu orçamento?")) {
                localStorage.removeItem("mm_montagens_carrinho");
                renderizarPaginaCarrinho();
                if(typeof atualizarIcones === 'function') atualizarIcones();
            }
        }

        function enviarParaWhatsApp() {
            const itens = getCarrinho();
            let texto = "Olá, MM Montagens! Gostaria de um orçamento para os seguintes itens:%0A%0A";
            
            itens.forEach(i => { 
                texto += `📦 *${i.qty}x* - ${i.nome} (Cód: ${i.codigo})%0A`; 
            });
            
            texto += "%0A*Aguardamos o retorno com os valores e prazos de entrega.*";
            window.open(`https://wa.me/5511932433674?text=${texto}`, "_blank");
        }

        window.addEventListener('DOMContentLoaded', renderizarPaginaCarrinho);
    </script>
</body>
</html>