---
import LayoutBase from '../../layouts/LayoutBase.astro';
import { galeriaCategorias } from '../../data/galeria.js';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  return galeriaCategorias.map(cat => ({
    params: { slug: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;

let fotos = [];
const pastasParaLer = Array.isArray(cat.folder) ? cat.folder : [cat.folder];

pastasParaLer.forEach(pasta => {
    const diretórioDaMidia = path.join(process.cwd(), 'public', 'midia', pasta);
    try {
        if (fs.existsSync(diretórioDaMidia)) {
            const arquivos = fs.readdirSync(diretórioDaMidia);
            const fotosDaPasta = arquivos
                .filter(file => /\.(jpg|jpeg|png|webp|avif|gif|svg)$/i.test(file))
                .map(file => `/midia/${pasta}/${file}`);
            fotos = [...fotos, ...fotosDaPasta];
        }
    } catch (error) {
        console.error(`Erro ao ler a pasta ${pasta}:`, error);
    }
});
---

<LayoutBase title={`${cat.nome} - Galeria MM Montagens`}>
    <section class="w-full pt-12 pb-20 bg-gray-50 min-h-screen">
        <div class="container mx-auto px-6 lg:px-24">
            
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
                <div>
                    <button onclick="history.back()" class="text-gray-400 hover:text-mm-blue font-bold text-xs uppercase tracking-widest flex items-center gap-2 mb-4 transition-all">
                        <i class="fas fa-arrow-left"></i> Voltar para Galeria
                    </button>
                    <h1 class="text-4xl font-black text-gray-900 uppercase tracking-tighter">{cat.nome}</h1>
                    <p class="text-gray-500 font-medium italic">Mostrando {fotos.length} itens de diversas categorias</p>
                </div>

                <a href={cat.linkCatalogo} class="bg-mm-blue hover:bg-mm-darkblue text-white px-8 py-4 rounded-xl font-black uppercase tracking-wide shadow-lg transition-all flex items-center gap-3 w-fit">
                    <i class="fas fa-shopping-cart"></i>
                    Ver Catálogo Completo
                </a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                {fotos.map((foto, index) => (
                    <div 
                        class="relative aspect-square bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl cursor-zoom-in group transition-all"
                        onclick={`window.openLightbox(${index})`}
                    >
                        <img 
                            src={foto} 
                            alt={`Foto ${index + 1}`} 
                            class="w-full h-full object-cover transition duration-500 group-hover:scale-110"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-mm-darkblue/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-mm-blue shadow-xl">
                                <i class="fas fa-search-plus"></i>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            {fotos.length === 0 && (
                <div class="text-center py-20">
                    <p class="text-gray-400 font-bold uppercase italic">Nenhuma foto encontrada.</p>
                </div>
            )}
        </div>
    </section>

    <div id="lightbox" class="fixed inset-0 z-[100] bg-black/95 hidden items-center justify-center select-none">
        <button onclick="window.closeLightbox()" class="absolute top-6 right-6 text-white text-4xl hover:text-mm-blue z-[110] transition-colors">
            <i class="fas fa-times"></i>
        </button>

        <button onclick="window.prevImage(event)" class="absolute left-4 md:left-8 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-4xl md:text-6xl z-[110] transition-all">
            <i class="fas fa-chevron-left"></i>
        </button>

        <div class="relative w-full h-full flex flex-col items-center justify-center p-4 md:p-12" onclick="window.closeLightbox()">
            <img id="lightbox-img" src="" class="max-w-full max-h-[85vh] rounded-lg shadow-2xl object-contain transition-all duration-300" onclick="event.stopPropagation()" />
            <div id="lightbox-counter" class="mt-4 text-gray-500 font-bold tracking-widest text-xs uppercase"></div>
        </div>

        <button onclick="window.nextImage(event)" class="absolute right-4 md:right-8 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-4xl md:text-6xl z-[110] transition-all">
            <i class="fas fa-chevron-right"></i>
        </button>
    </div>
</LayoutBase>

<script is:inline define:vars={{ fotos }}>
    let currentIndex = 0;
    const lightbox = document.getElementById('lightbox');
    const img = document.getElementById('lightbox-img');
    const counter = document.getElementById('lightbox-counter');

    window.openLightbox = function(index) {
        currentIndex = index;
        updateLightbox();
        lightbox.classList.replace('hidden', 'flex');
        document.body.style.overflow = 'hidden';
    };

    window.closeLightbox = function() {
        lightbox.classList.replace('flex', 'hidden');
        document.body.style.overflow = 'auto';
    };

    window.nextImage = function(e) {
        if(e) e.stopPropagation();
        currentIndex = (currentIndex + 1) % fotos.length;
        updateLightbox();
    };

    window.prevImage = function(e) {
        if(e) e.stopPropagation();
        currentIndex = (currentIndex - 1 + fotos.length) % fotos.length;
        updateLightbox();
    };

    function updateLightbox() {
        img.style.opacity = '0';
        setTimeout(() => {
            img.src = fotos[currentIndex];
            counter.innerText = `${currentIndex + 1} / ${fotos.length}`;
            img.style.opacity = '1';
        }, 100);
    }

    // Navegação via teclado
    document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'ArrowRight') window.nextImage();
        if (e.key === 'ArrowLeft') window.prevImage();
        if (e.key === 'Escape') window.closeLightbox();
    });
</script>