---
import LayoutBase from '../layouts/LayoutBase.astro';
---

<LayoutBase title="MM Montagens - Contato">
    <style>
        /* Corte diagonal da seção de informações de contato (sobe para a direita) */
        .clip-slant-contato {
            clip-path: polygon(0 5vw, 100% 0, 100% 100%, 0% 100%);
        }
    </style>

    <section class="relative w-full h-[260px] flex items-center justify-center overflow-hidden border-t border-mm-blue/20">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1596524430615-b46475ddff6e?auto=format&fit=crop&q=80');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1489c8]/95 via-[#1489c8]/90 to-[#0e6ba0]/95 mix-blend-multiply"></div>
        
        <div class="relative z-10 text-center text-white flex flex-col mt-4">
            <h1 class="text-[55px] md:text-[65px] font-black leading-none tracking-tight drop-shadow-md">FALE</h1>
            <h2 class="text-[55px] md:text-[65px] font-light leading-none tracking-tight drop-shadow-md -mt-2">CONOSCO</h2>
        </div>
    </section>

    <section class="w-full py-20 bg-white">
        <div class="container mx-auto px-8 lg:px-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                
                <div>
                    <form action="#" method="POST" class="flex flex-col gap-6">
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-center gap-4">
                            <label for="nome" class="text-[#444444] text-[15px]">Nome <strong>(*)</strong></label>
                            <input type="text" id="nome" name="nome" required class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-cyan transition rounded-sm">
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-center gap-4">
                            <label for="email" class="text-[#444444] text-[15px]">E-mail <strong>(*)</strong></label>
                            <input type="email" id="email" name="email" required class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-cyan transition rounded-sm">
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-center gap-4">
                            <label for="telefone" class="text-[#444444] text-[15px]">Telefone <strong>(*)</strong></label>
                            <input type="tel" id="telefone" name="telefone" required class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-cyan transition rounded-sm">
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-start gap-4">
                            <label for="mensagem" class="text-[#444444] text-[15px] pt-2">Mensagem <strong>(*)</strong></label>
                            <textarea id="mensagem" name="mensagem" rows="6" required class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-cyan transition rounded-sm resize-none"></textarea>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-start gap-4 mt-2">
                            <label class="text-[#444444] text-[15px]">Termos <strong>(*)</strong></label>
                            <div class="flex items-start gap-3">
                                <input type="checkbox" id="termos" required class="mt-1.5 w-4 h-4 text-mm-cyan border-gray-300 rounded focus:ring-mm-cyan">
                                <label for="termos" class="text-[#555555] text-[14px] leading-relaxed">
                                    Eu concordo com os <a href="#" class="text-mm-cyan hover:underline">Termos de Uso</a> e <a href="#" class="text-mm-cyan hover:underline">Política e Privacidade</a> declaro permitir o uso dos meus dados pelo departamento de marketing e vendas da MMontagens.
                                </label>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] gap-4 mt-2">
                            <div></div> <div>
                                <button type="submit" class="bg-mm-cyan hover:bg-[#158eb5] text-white px-8 py-2.5 rounded-sm font-medium transition shadow-sm">
                                    Enviar
                                </button>
                            </div>
                        </div>

                    </form>
                </div>

                <div class="w-full h-[400px] lg:h-full min-h-[400px] bg-gray-200 border border-gray-300 p-1 relative">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3656.402410887163!2d-46.568460684346875!3d-23.58988698466858!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce5c63556064f7%3A0xc0fb8c5fbf930777!2sR.%20Marcello%20M%C3%BCller%2C%20766%20-%20Vila%20Independencia%2C%20S%C3%A3o%20Paulo%20-%20SP%2C%2003223-060!5e0!3m2!1spt-BR!2sbr!4v1680000000000!5m2!1spt-BR!2sbr" 
                        width="100%" 
                        height="100%" 
                        style="border:0;" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>

            </div>
        </div>
    </section>

    <section class="w-full bg-mm-light pt-24 pb-16 clip-slant-contato -mt-8 relative z-10">
        <div class="container mx-auto px-8 lg:px-24">
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center pt-8">
                
                <div class="flex flex-col items-center">
                    <i class="fas fa-envelope text-[40px] text-mm-cyan mb-4"></i>
                    <h3 class="text-gray-500 text-[13px] font-bold tracking-widest uppercase mb-4">E-mail</h3>
                    <a href="mailto:mm.montagens@uol.com.br" class="text-gray-700 font-bold hover:text-mm-cyan transition">mm.montagens@uol.com.br</a>
                </div>

                <div class="flex flex-col items-center">
                    <i class="fas fa-phone-alt text-[40px] text-mm-cyan mb-4"></i>
                    <h3 class="text-gray-500 text-[13px] font-bold tracking-widest uppercase mb-4">Telefone</h3>
                    <div class="text-gray-700 font-bold leading-relaxed">
                        <p>(11) 99803-8196</p>
                    </div>
                </div>

                <div class="flex flex-col items-center">
                    <i class="fas fa-map-marker-alt text-[40px] text-mm-cyan mb-4"></i>
                    <h3 class="text-gray-500 text-[13px] font-bold tracking-widest uppercase mb-4">Endereço</h3>
                    <div class="text-gray-700 font-bold leading-relaxed">
                        <p>R. Marcello Müller, 766</p>
                        <p>Vila Independência,</p>
                        <p>São Paulo - SP, 03223-060</p>
                    </div>
                </div>

            </div>
        </div>
    </section>
</LayoutBase>