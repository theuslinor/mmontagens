---
import LayoutBase from '../layouts/LayoutBase.astro';
---

<LayoutBase title="MM Montagens - Contato">
    <style>
        .clip-slant-contato {
            clip-path: polygon(0 5vw, 100% 0, 100% 100%, 0% 100%);
        }
    </style>

    <section class="relative w-full h-[260px] flex items-center justify-center overflow-hidden border-t border-mm-blue/20">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1596524430615-b46475ddff6e?auto=format&fit=crop&q=80');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1489c8]/95 via-[#1489c8]/90 to-[#0e6ba0]/95 mix-blend-multiply"></div>
        
        <div class="relative z-10 text-center text-white flex flex-col mt-4">
            <h1 class="text-[55px] md:text-[65px] font-black leading-none tracking-tight drop-shadow-md uppercase">Fale</h1>
            <h2 class="text-[55px] md:text-[65px] font-light leading-none tracking-tight drop-shadow-md -mt-2 uppercase">Conosco</h2>
        </div>
    </section>

    <section class="w-full py-20 bg-white">
        <div class="container mx-auto px-8 lg:px-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                
                <div>
                    <div class="flex flex-col gap-6">
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-center gap-4">
                            <label for="nome" class="text-[#444444] text-[15px]">Nome <strong>(*)</strong></label>
                            <input type="text" id="nome" class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-blue transition rounded-sm">
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-center gap-4">
                            <label for="email" class="text-[#444444] text-[15px]">E-mail</label>
                            <input type="email" id="email" class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-blue transition rounded-sm">
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-center gap-4">
                            <label for="telefone" class="text-[#444444] text-[15px]">Telefone</label>
                            <input type="tel" id="telefone" class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-blue transition rounded-sm">
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-start gap-4">
                            <label for="mensagem" class="text-[#444444] text-[15px] pt-2">Mensagem <strong>(*)</strong></label>
                            <textarea id="mensagem" rows="6" class="w-full border border-gray-300 px-3 py-2 outline-none focus:border-mm-blue transition rounded-sm resize-none"></textarea>
                        </div>
                        
                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] items-start gap-4 mt-2">
                            <label class="text-[#444444] text-[15px]">Termos <strong>(*)</strong></label>
                            <div class="flex items-start gap-3">
                                <input type="checkbox" id="termos" class="mt-1.5 w-4 h-4 text-mm-blue border-gray-300 rounded focus:ring-mm-blue">
                                <label for="termos" class="text-[#555555] text-[14px] leading-relaxed">
                                    Eu concordo com os Termos de Uso e permito o contato comercial da MM Montagens via WhatsApp. <strong>(*)</strong>
                                </label>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-[100px_1fr] gap-4 mt-2">
                            <div></div> 
                            <div>
                                <button onclick="enviarContatoZap()" class="bg-[#25D366] hover:bg-[#20ba5a] text-white px-10 py-4 rounded-lg font-black uppercase transition shadow-lg flex items-center gap-3">
                                    <i class="fab fa-whatsapp text-xl"></i> Enviar via WhatsApp
                                </button>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="w-full h-[400px] lg:h-full min-h-[400px] bg-gray-200 border border-gray-300 p-1 relative rounded-xl overflow-hidden">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3656.742385317578!2d-46.5613328!3d-23.5776609!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94ce5c24e6f4773d%3A0x6335a96328325a7a!2sR.%20Marcello%20M%C3%BCller%2C%20766%20-%20Vila%20Independencia%2C%20S%C3%A3o%20Paulo%20-%20SP%2C%2003223-060!5e0!3m2!1spt-BR!2sbr!4v1712615000000" 
                        width="100%" 
                        height="100%" 
                        style="border:0;" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>

            </div>
        </div>
    </section>

    <script is:inline>
        window.enviarContatoZap = function() {
            const nome = document.getElementById('nome').value.trim();
            const email = document.getElementById('email').value.trim();
            const tel = document.getElementById('telefone').value.trim();
            const msg = document.getElementById('mensagem').value.trim();
            const termos = document.getElementById('termos').checked;

            if (!nome || !msg) {
                alert("Por favor, preencha o seu Nome e a sua Mensagem.");
                return;
            }

            if (!termos) {
                alert("Você precisa concordar com os termos antes de enviar.");
                return;
            }

            let texto = "Olá, MM Montagens!%0A";
            texto += "Gostaria de entrar em contato através do site:%0A%0A";
            texto += `*Nome:* ${nome}%0A`;
            if (email) texto += `*E-mail:* ${email}%0A`;
            if (tel) texto += `*Telefone:* ${tel}%0A`;
            texto += `*Mensagem:* ${msg}`;

            window.open(`https://wa.me/5511915287830?text=${texto}`, "_blank");
        }
    </script>
</LayoutBase>