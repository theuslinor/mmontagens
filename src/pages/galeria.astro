---
import LayoutBase from '../layouts/LayoutBase.astro';
import { galeriaCategorias } from '../data/galeria.js';
---

<LayoutBase title="Galeria de Projetos - MM Montagens">
    <section class="relative w-full h-[280px] flex items-center justify-center overflow-hidden border-t border-mm-blue/20">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1504917595217-d4dc5ebe6122?auto=format&fit=crop&q=80');"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1489c8]/95 via-[#1489c8]/85 to-[#0e6ba0]/95 mix-blend-multiply"></div>
        <div class="relative z-10 text-center text-white flex flex-col mt-4">
            <h1 class="text-[75px] md:text-[90px] font-black leading-none tracking-tight drop-shadow-md uppercase">Galeria</h1>
        </div>
    </section>

    <section class="w-full py-20 bg-white min-h-[500px]">
        <div class="container mx-auto px-8 lg:px-24">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                
                {galeriaCategorias.map(cat => (
                    <a href={`/galeria/${cat.slug}`} class="relative w-full h-[300px] bg-gray-100 rounded-3xl overflow-hidden group cursor-pointer shadow-md hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                        {/* Imagem Arredondada via Container */}
                        <img src={cat.capa.startsWith('/') ? cat.capa : `/${cat.capa}`} alt={cat.nome} class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                        
                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition duration-300"></div>
                        
                        <div class="absolute bottom-6 left-6 right-6">
                            <h3 class="text-white font-black text-xl leading-tight drop-shadow-md uppercase italic tracking-tighter">{cat.nome}</h3>
                            <span class="text-mm-yellow text-[10px] font-black uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all transform translate-y-2 group-hover:translate-y-0 flex items-center gap-2 mt-2">
                                Ver Álbum <i class="fas fa-arrow-right"></i>
                            </span>
                        </div>
                    </a>
                ))}

            </div>
        </div>
    </section>
</LayoutBase>